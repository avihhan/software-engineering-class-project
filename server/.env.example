FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-change-in-production

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=

PORT=5000

# Comma-separated extra browser origins for CORS (LAN IPs, Cloud Run frontends, production domains).
# Example: https://your-mobile-web.run.app,https://your-admin.run.app,http://192.168.1.10:3001
CORS_ORIGINS=

# Lemon Squeezy billing (test keys initially)
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_REDIRECT_URL=
